{
  "name": "client-monitor",
  "displayName": "Client Monitor",
  "description": "Client-side monitoring extension",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clientMonitor.reconnect",
        "title": "Reconnect to Monitor Server"
      }
    ],
    "configuration": {
      "title": "Client Monitor",
      "properties": {
        "clientMonitor.servers": {
          "type": "array",
          "default": [
            {
              "url": "ws://localhost:54321",
              "serverId": "uwb-01"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "description": "WebSocket server URL"
              },
              "serverId": {
                "type": "string",
                "description": "Unique identifier for this server instance"
              }
            }
          },
          "description": "List of monitor servers to connect to"
        },
        "clientMonitor.clientKey": {
          "type": "string",
          "description": "Unique client key for authentication (generated automatically if empty)"
        },
        "clientMonitor.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to all configured servers on startup"
        },
        "clientMonitor.reportInterval": {
          "type": "number",
          "default": 60000,
          "description": "Shared heartbeat interval in milliseconds for all connections"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.3.0"
  }
}
