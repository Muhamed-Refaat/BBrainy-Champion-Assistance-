{
    "name":  "client-monitor",
    "displayName":  "Client Monitor",
    "description":  "Client-side monitoring extension for BBrainy Champion Assistant",
    "version":  "1.0.0",
    "license": "UNLICENSED",
    "repository": {
        "type": "git",
        "url": "https://example.com/bbrainy-champion-assistance.git"
    },
    "icon":  "resources/icon.png",
    "engines":  {
                    "vscode":  "^1.85.0"
                },
    "categories":  [
                       "Other"
                   ],
    "activationEvents":  [
                             "onStartupFinished"
                         ],
    "main":  "./out/extension.js",
    "contributes":  {
                        "commands":  [
                                         {
                                             "command":  "clientMonitor.setServerKey",
                                             "title":  "Client Monitor: Set Server Key"
                                         },

                                         {
                                             "command":  "clientMonitor.setClientReleasePath",
                                             "title":  "Client Monitor: Set Client Release Folder"
                                         },

                                         {
                                             "command":  "clientMonitor.showStatus",
                                             "title":  "Client Monitor: Show Connection Status"
                                         },
                                         {
                                             "command":  "clientMonitor.resetToDefault",
                                             "title":  "Client Monitor: Reset to Default Server"
                                         },
                                         {
                                             "command":  "clientMonitor.statusBarMenu",
                                             "title":  "Client Monitor: Open Action Menu"
                                         },
                                         {
                                             "command":  "clientMonitor.showUsageReport",
                                             "title":  "Client Monitor: Show BBrainy Usage Report"
                                         },
                                         {
                                             "command":  "clientMonitor.setNotifier",
                                             "title":  "Client Monitor: Set BBrainy Notifier"
                                         },
                                         {
                                             "command":  "clientMonitor.closeNotifier",
                                             "title":  "Client Monitor: Close BBrainy Notifier"
                                         }
                                     ],
                        "configuration":  {
                                              "title":  "Client Monitor",
                                              "properties":  {
                                                                 "clientMonitor.serverKey":  {
                                                                                                 "type":  "string",
                                                                                                 "default":  "default",
                                                                                                 "description":  "Server key to connect to. Must match the server\u0027s published key. Use \u0027default\u0027 for the default server."
                                                                                             },

                                                                 "clientMonitor.syncPath":  {
                                                                                                "type":  "string",
                                                                                                "default":  "\\\\cai1-users\\share\\AI-Champion-Assist\\sync",
                                                                                                "description":  "Internal communication path. Leave empty to disable."
                                                                                            },
                                                                 "clientMonitor.clientReleasePath":  {
                                                                                                         "type":  "string",
                                                                                                         "default":  "\\\\cai1-users\\share\\AI-Champion-Assist\\client-release",
                                                                                                         "description":  "Path to shared folder for client extension auto-updates (VSIX files). Leave empty to disable."
                                                                                                     }

                                                             }
                                          }
                    },
    "scripts":  {
                    "vscode:prepublish":  "node esbuild.js --production",
                    "compile":  "node esbuild.js --production",
                    "build":  "node esbuild.js --production",
                    "package":  "node esbuild.js --production && npx @vscode/vsce package --no-dependencies --allow-missing-repository --skip-license",
                    "watch":  "tsc -watch -p ./"
                },
    "dependencies":  {},

    "devDependencies":  {
                            "@types/node":  "^20.x",
                            "@types/vscode":  "^1.85.0",

                            "@vscode/vsce":  "^3.7.1",
                            "esbuild":  "^0.27.3",
                            "typescript":  "^5.3.0"
                        }
}
